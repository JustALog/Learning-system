# ============================================
# Database Configuration
# ============================================
# For Docker: use 'db' as host
# For Local: use 'localhost'
DB_HOST=localhost
DB_PORT=3306
DB_NAME=course_management
DB_USER=root
DB_PASS=root

# ============================================
# JWT Configuration
# ============================================
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=24h

# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=development

