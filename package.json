{
  "name": "course_management",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w client\" \"npm run dev -w server\"",
    "install:all": "npm install && npm install -w client && npm install -w server",
    "build:client": "npm run build -w client",
    "start:server": "npm run start -w server",
    "test:server": "npm run test -w server",
    "migrate": "sudo npm run migrate -w server",
    "seed": "sudo npm run seed -w server"
  },
  "devDependencies": {
    "concurrently": "^8.2.1"
  },
  "dependencies": {
    "all": "^0.0.0",
    "react": "^19.2.4",
    "vite": "^8.0.1"
  }
}
